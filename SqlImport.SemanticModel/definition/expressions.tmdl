expression MyFunction =
		let
		    Source = (RangeStart as datetime, RangeEnd as datetime) => let
		    Source = Sql.Databases("modelingsql.database.windows.net"),
		    AdventureWorksLT = Source{[Name="AdventureWorksLT"]}[Data],
		    SalesLT_SalesOrderDetail = AdventureWorksLT{[Schema="SalesLT",Item="SalesOrderDetail"]}[Data],
		    #"Removed Columns" = Table.RemoveColumns(SalesLT_SalesOrderDetail,{"LineTotal"}),
		    #"Filtered Rows" = Table.SelectRows(#"Removed Columns", each [ModifiedDate] > RangeStart and [ModifiedDate] <= RangeEnd)
		in
		    #"Filtered Rows"
		in
		    Source
